      "typeVersion": 4.1,
      "position": [700, 200]
    },
    {
      "parameters": {
        "jsCode": "const tasks = [\n  { name: '🚀 Kickoff Call', offset: 0 },\n  { name: '🔍 Tracking Audit', offset: 1 },\n  { name: '📊 Account Analysis', offset: 2 },\n  { name: '💡 Creative Briefing', offset: 3 },\n  { name: '🎬 Creative Produktion', offset: 5 },\n  { name: '👁️ Kunden Review', offset: 8 },\n  { name: '🚀 Campaign Launch', offset: 10 },\n  { name: '📈 Performance Tag 3', offset: 13 },\n  { name: '🏆 Performance Tag 7', offset: 17 }\n];\nconst now = new Date();\nreturn tasks.map(t => ({\n  json: {\n    name: t.name,\n    offset: t.offset,\n    dueDate: new Date(now.getTime() + t.offset * 86400000).getTime()\n  }\n}));"
      },
      "name": "Code: Tasks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [900, 200]
    }
