    {
      "parameters": {
        "operation": "search",
        "baseId": "appbGhxy9I18oIS8E",
        "tableId": "tbluuOSL8CTyIo0Ng",
        "options": {
          "filterByFormula": "AND({Status}='Active', FIND('Paid Ads', {Services}))"
        }
      },
      "name": "Airtable: Neue Kunden",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.0,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.clickup.com/api/v2/space/90040311585/folder",
